---
const navigation = [
  { label: 'Работы', href: '#works' },
  { label: 'Обо мне', href: '#about' },
  { label: 'Процесс', href: '#process' },
  { label: 'FAQ', href: '#faq' },
] as const;
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="logo" href="#main-content" aria-label="FORMA — на главную"
      >FOR<span>MA*</span></a
    >

    <nav class="desktop-navigation" aria-label="Основная навигация">
      <ul>
        {
          navigation.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a class="button button--compact desktop-action" href="#contact"
      >Обсудить идею</a
    >

    <details class="mobile-navigation">
      <summary>Меню</summary>
      <nav aria-label="Мобильная навигация">
        <ul>
          {
            navigation.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
          <li><a href="#contact">Обсудить идею</a></li>
        </ul>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: absolute;
    z-index: 10;
    inset: 0 0 auto;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-text) 20%, transparent);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    min-height: 5.25rem;
    gap: var(--space-8);
  }

  .logo {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 0.8;
    text-decoration: none;
  }

  .logo span {
    display: block;
    margin-inline-start: 1.15rem;
  }

  ul {
    display: flex;
    justify-content: center;
    gap: clamp(1rem, 3vw, 2.5rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  nav a {
    color: var(--color-text);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
  }

  nav a:hover {
    color: var(--color-accent-soft);
  }

  .mobile-navigation {
    display: none;
    justify-self: end;
  }

  @media (max-width: 52rem) {
    .site-header__inner {
      display: flex;
      justify-content: space-between;
      min-height: 4.5rem;
    }

    .desktop-navigation,
    .desktop-action {
      display: none;
    }

    .mobile-navigation {
      display: block;
    }

    summary {
      cursor: pointer;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      list-style: none;
      text-transform: uppercase;
    }

    summary::-webkit-details-marker {
      display: none;
    }

    details[open] summary {
      color: var(--color-accent-soft);
    }

    .mobile-navigation nav {
      position: absolute;
      inset: 4.5rem 0 auto;
      padding: var(--space-8) var(--page-padding);
      border-bottom: 1px solid var(--color-border);
      background: color-mix(in srgb, var(--color-background) 96%, transparent);
      backdrop-filter: blur(1rem);
    }

    .mobile-navigation ul {
      align-items: flex-end;
      flex-direction: column;
      gap: var(--space-6);
    }
  }
</style>
