<section class="contact" id="contact" aria-labelledby="contact-title">
  <div class="container">
    <header class="contact__header">
      <p class="eyebrow">07 / Contact</p>
      <h2 id="contact-title">
        У тебя есть идея.<br />Давай придадим ей <em>форму.</em>
      </h2>
      <p>
        Расскажи, что хочешь выразить. После подключения формы мастер сможет
        уточнить детали и предложить следующий шаг.
      </p>
    </header>

    <div class="contact__layout">
      <div class="contact__aside">
        <p class="contact__city">Omsk<br />Private studio</p>
        <dl>
          <div><dt>Формат</dt><dd>По предварительной записи</dd></div>
          <div><dt>Ответ</dt><dd>Срок уточняется у мастера</dd></div>
          <div><dt>Связь</dt><dd>Контакты будут добавлены</dd></div>
        </dl>
        <p class="contact__concept">
          Демонстрационный проект · не клиентская работа
        </p>
      </div>

      <form class="contact-form" data-demo-form>
        <div class="form-field">
          <label for="name">Как тебя зовут?</label>
          <input
            id="name"
            name="name"
            type="text"
            autocomplete="name"
            required
          />
        </div>

        <div class="form-field">
          <label for="contact-method">Телефон или ник в Telegram</label>
          <input
            id="contact-method"
            name="contact"
            type="text"
            autocomplete="tel"
            required
          />
        </div>

        <div class="form-field form-field--wide">
          <label for="idea">Расскажи об идее</label>
          <textarea id="idea" name="idea" rows="4" required></textarea>
        </div>

        <div class="form-field">
          <label for="placement">Размер и место нанесения</label>
          <input id="placement" name="placement" type="text" />
        </div>

        <div class="form-field">
          <label for="reference">Прикрепить референс</label>
          <input
            id="reference"
            name="reference"
            type="file"
            accept="image/png,image/jpeg,image/webp"
          />
        </div>

        <label class="form-consent">
          <input name="consent" type="checkbox" required />
          <span
            >Соглашаюсь на обработку данных из формы для ответа на заявку.</span
          >
        </label>
        <p class="form-policy">
          Подробнее об обработке данных — в <a href="/privacy/"
            >политике конфиденциальности</a
          >.
        </p>

        <div class="contact-form__footer">
          <button class="button" type="submit">Отправить идею</button>
          <p class="form-status" role="status" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-demo-form]');
  const status = form?.querySelector<HTMLElement>('.form-status');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    if (status) {
      status.textContent =
        'Это демонстрационная форма. Перед запуском подключим отправку заявок мастеру.';
    }
  });
</script>

