---
const privacyUrl = `${import.meta.env.BASE_URL}privacy/`;
---

<footer class="footer">
  <div class="footer__inner container">
    <a
      class="footer__logo"
      href="#main-content"
      aria-label="FORMA — к началу страницы"
    >
      FOR<span>MA*</span>
    </a>

    <div class="footer__location">
      <span>55.0084° N</span>
      <strong>Омск</strong>
      <span>73.3945° E</span>
    </div>

    <nav aria-label="Навигация в подвале">
      <a href="#works">Работы</a>
      <a href="#about">О мастере</a>
      <a href="#process">Процесс</a>
      <a href="#faq">FAQ</a>
      <a href="#contact">Запись</a>
    </nav>

    <div class="footer__contacts">
      <p>Контакты реального мастера<br />добавляются перед запуском</p>
      <span>Telegram · VK</span>
    </div>

    <div class="footer__legal">
      <span>© 2026 FORMA* · Portfolio concept</span>
      <a href={privacyUrl}>Политика конфиденциальности</a>
      <span>GitHub проекта · после публикации</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-background);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 2fr 3fr 2fr 3fr;
    gap: clamp(2rem, 5vw, 5rem);
    padding-block: clamp(4rem, 8vw, 7rem) var(--space-8);
  }

  .footer__logo {
    align-self: start;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 500;
    line-height: 0.78;
    text-decoration: none;
  }

  .footer__logo span {
    display: block;
    margin-inline-start: 1.5em;
  }

  .footer__location {
    display: grid;
    align-content: start;
    gap: var(--space-2);
  }

  .footer__location strong {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 2rem);
    font-weight: 500;
    text-transform: uppercase;
  }

  .footer__location span,
  .footer__contacts span,
  .footer__legal {
    color: var(--color-text-muted);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  nav {
    display: grid;
    align-content: start;
    gap: var(--space-2);
  }

  nav a,
  .footer__legal a {
    color: var(--color-text);
    text-decoration: none;
  }

  nav a {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer__contacts p {
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.86rem;
  }

  .footer__legal {
    display: flex;
    grid-column: 1 / -1;
    justify-content: space-between;
    gap: var(--space-6);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .footer__legal a {
    color: var(--color-text-muted);
  }

  @media (max-width: 52rem) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 36rem) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__legal {
      align-items: flex-start;
      flex-direction: column;
      grid-column: auto;
    }
  }
</style>
