---
import { Image } from 'astro:assets';
import artistImage from '../assets/images/about-tattoo-artist.png';

const facts = ['Омск', 'Индивидуальные эскизы', 'Работа по записи'] as const;
---

<section class="about" id="about" aria-labelledby="about-title">
  <div class="about__inner container">
    <figure class="about__visual">
      <div class="about__image">
        <Image
          src={artistImage}
          alt="Портрет тату-мастера в студии"
          widths={[480, 720, 960]}
          sizes="(max-width: 720px) 88vw, 42vw"
          loading="lazy"
          quality={84}
        />
      </div>
      <figcaption>Concept portrait · not a real client</figcaption>
      <span class="about__stamp" aria-hidden="true">FORMA<br />OMSK</span>
    </figure>

    <div class="about__content">
      <p class="eyebrow">02 / About</p>
      <h2 id="about-title">Не просто<br />изображение<br />на коже</h2>
      <div class="about__copy">
        <p>
          Я работаю с личными историями, образами и ощущениями, превращая их в
          индивидуальные эскизы. Для меня важно, чтобы татуировка сочеталась с
          телом и оставалась близкой человеку спустя годы.
        </p>
        <p>
          Перед сеансом мы обсуждаем идею, размер, расположение и детали будущей
          работы. Ты понимаешь каждый этап и можешь задать любые вопросы.
        </p>
      </div>

      <ul class="about__facts" aria-label="Кратко о мастере">
        {
          facts.map((fact, index) => (
            <li>
              <span>0{index + 1}</span>
              {fact}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    padding-block: clamp(6rem, 12vw, 12rem);
    overflow: clip;
    background: var(--color-background);
  }

  .about::after {
    position: absolute;
    content: '';
    width: min(34vw, 32rem);
    aspect-ratio: 1;
    inset: 8% -12% auto auto;
    border: 1px solid var(--color-border);
    border-radius: 50%;
  }

  .about__inner {
    display: grid;
    grid-template-columns: minmax(17rem, 5fr) minmax(0, 7fr);
    align-items: center;
    gap: clamp(3rem, 8vw, 9rem);
  }

  .about__visual {
    position: relative;
    margin: 0;
  }

  .about__image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    clip-path: polygon(0 0, 92% 0, 100% 8%, 100% 100%, 0 100%);
  }

  .about__image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.55) contrast(1.06);
  }

  figcaption {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .about__stamp {
    position: absolute;
    inset: 8% -2.5rem auto auto;
    display: grid;
    width: 5.5rem;
    aspect-ratio: 1;
    place-content: center;
    border: 1px solid var(--color-accent-soft);
    border-radius: 50%;
    color: var(--color-accent-soft);
    font-family: var(--font-display);
    font-size: 0.65rem;
    line-height: 1.3;
    text-align: center;
    transform: rotate(12deg);
  }

  .about__content {
    position: relative;
    z-index: 1;
  }

  h2 {
    margin-block: var(--space-6) var(--space-12);
    font-size: clamp(2.8rem, 6.3vw, 6.8rem);
    letter-spacing: -0.06em;
    text-transform: uppercase;
  }

  .about__copy {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    color: var(--color-text-muted);
  }

  .about__facts {
    display: grid;
    margin: var(--space-12) 0 0;
    padding: 0;
    border-bottom: 1px solid var(--color-border);
    list-style: none;
  }

  .about__facts li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .about__facts span {
    color: var(--color-accent-soft);
  }

  @media (max-width: 52rem) {
    .about__inner {
      grid-template-columns: 1fr;
    }

    .about__visual {
      width: min(88%, 32rem);
    }

    .about__content {
      width: min(100%, 43rem);
      margin-inline-start: auto;
    }
  }

  @media (max-width: 36rem) {
    .about__copy {
      grid-template-columns: 1fr;
    }

    .about__stamp {
      inset-inline-end: -1.5rem;
    }
  }
</style>
