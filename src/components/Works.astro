---
import { Image } from 'astro:assets';
import botanicalImage from '../assets/images/work-botanical.png';
import geometricImage from '../assets/images/work-geometric.png';
import shoulderImage from '../assets/images/work-shoulder.png';
import typographicImage from '../assets/images/work-typographic.png';

const works = [
  {
    image: botanicalImage,
    alt: 'Тонкая ботаническая татуировка на руке',
    number: '01',
    title: 'Botanical flow',
    meta: 'Fine line · arm',
    className: 'work-card--portrait',
  },
  {
    image: geometricImage,
    alt: 'Геометрическая чёрная татуировка на предплечье',
    number: '02',
    title: 'Construct',
    meta: 'Blackwork · forearm',
    className: 'work-card--wide',
  },
  {
    image: shoulderImage,
    alt: 'Абстрактная линейная татуировка на лопатке',
    number: '03',
    title: 'Movement',
    meta: 'Abstract · shoulder',
    className: 'work-card--offset',
  },
  {
    image: typographicImage,
    alt: 'Экспериментальная графическая татуировка на голени',
    number: '04',
    title: 'Unknown signs',
    meta: 'Experimental · leg',
    className: 'work-card--final',
  },
] as const;
---

<section class="works" id="works" aria-labelledby="works-title">
  <div class="container">
    <header class="works__header">
      <div>
        <p class="eyebrow">01 / Selected works</p>
        <h2 id="works-title">Работы говорят<br />точнее слов</h2>
      </div>
      <p class="works__intro">
        Каждая композиция создаётся для конкретного человека — с учётом идеи,
        характера и анатомии.
      </p>
    </header>

    <div class="works__grid">
      {
        works.map((work) => (
          <figure class:list={['work-card', work.className]}>
            <div class="work-card__image">
              <Image
                src={work.image}
                alt={work.alt}
                widths={[420, 640, 720, 900]}
                sizes="(max-width: 720px) 92vw, 46vw"
                loading="lazy"
                quality={82}
              />
              <span aria-hidden="true">F—{work.number}</span>
            </div>
            <figcaption>
              <strong>{work.title}</strong>
              <span>{work.meta}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <div class="works__footer">
      <p>Concept visuals · not client work</p>
      <a class="button" href="#contact">Хочу обсудить свою идею</a>
    </div>
  </div>
</section>

<style>
  .works {
    position: relative;
    padding-block: clamp(6rem, 11vw, 11rem);
    overflow: clip;
    background: var(--color-text);
    color: var(--color-background);
  }

  .works::before {
    position: absolute;
    content: 'FORMA';
    inset: 3rem -0.08em auto auto;
    color: color-mix(in srgb, var(--color-background) 5%, transparent);
    font-family: var(--font-display);
    font-size: clamp(5rem, 20vw, 20rem);
    font-weight: 500;
    line-height: 0.8;
    pointer-events: none;
  }

  .works__header {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 8fr) minmax(16rem, 4fr);
    align-items: end;
    gap: var(--space-8);
    margin-bottom: clamp(4rem, 8vw, 8rem);
  }

  .works .eyebrow {
    color: color-mix(in srgb, var(--color-background) 65%, transparent);
  }

  h2 {
    margin-top: var(--space-6);
    font-size: clamp(2.8rem, 7.5vw, 7.5rem);
    letter-spacing: -0.06em;
    text-transform: uppercase;
  }

  .works__intro {
    max-width: 28rem;
    color: color-mix(in srgb, var(--color-background) 68%, transparent);
  }

  .works__grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: clamp(1.5rem, 4vw, 4rem) clamp(1rem, 2.5vw, 2.5rem);
  }

  .work-card {
    margin: 0;
  }

  .work-card--portrait {
    grid-column: 1 / span 5;
  }

  .work-card--wide {
    grid-column: 7 / -1;
    margin-top: clamp(4rem, 10vw, 10rem);
  }

  .work-card--offset {
    grid-column: 2 / span 4;
    margin-top: clamp(2rem, 5vw, 5rem);
  }

  .work-card--final {
    grid-column: 7 / span 5;
    margin-top: clamp(7rem, 14vw, 14rem);
  }

  .work-card__image {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
  }

  .work-card--portrait .work-card__image,
  .work-card--offset .work-card__image,
  .work-card--final .work-card__image {
    aspect-ratio: 3 / 4;
  }

  .work-card--wide .work-card__image {
    aspect-ratio: 3 / 2;
  }

  .work-card__image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.72) contrast(1.04);
    transition: transform 500ms cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  .work-card:hover .work-card__image :global(img) {
    transform: scale(1.025);
  }

  .work-card__image > span {
    position: absolute;
    inset: var(--space-4) var(--space-4) auto auto;
    display: grid;
    width: 3.5rem;
    aspect-ratio: 1;
    place-items: center;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-text);
    font-size: 0.66rem;
  }

  figcaption {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid
      color-mix(in srgb, var(--color-background) 18%, transparent);
    margin-top: var(--space-4);
  }

  figcaption strong {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  figcaption span,
  .works__footer p {
    color: color-mix(in srgb, var(--color-background) 60%, transparent);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .works__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    margin-top: clamp(5rem, 10vw, 10rem);
    padding-top: var(--space-8);
    border-top: 1px solid
      color-mix(in srgb, var(--color-background) 18%, transparent);
  }

  @media (max-width: 52rem) {
    .works__header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .works__grid {
      grid-template-columns: 1fr 1fr;
    }

    .work-card--portrait,
    .work-card--wide,
    .work-card--offset,
    .work-card--final {
      grid-column: auto;
      margin-top: 0;
    }

    .work-card--wide,
    .work-card--final {
      margin-top: 4rem;
    }

    .work-card--wide .work-card__image {
      aspect-ratio: 3 / 4;
    }

    .works__footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 36rem) {
    .works__grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .work-card--wide,
    .work-card--final {
      margin-top: 0;
    }

    .work-card--portrait,
    .work-card--offset,
    .work-card--final {
      width: 88%;
    }

    .work-card--wide {
      width: 92%;
      margin-inline-start: auto;
    }

    .work-card--offset {
      margin-inline-start: auto;
    }

    figcaption {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
